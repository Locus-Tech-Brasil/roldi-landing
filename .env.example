# Locus Seguros — variáveis de ambiente (frontend do MOTOR)
# Copie para .env e preencha. NUNCA commitar o .env real.
# Só chaves VITE_* (públicas, expostas no bundle) vivem aqui.
# Todo secret de servidor → Supabase Secrets / env do deploy, nunca no repositório.

VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_REF"
